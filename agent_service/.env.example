# ─────────────────────────────────────────────────────────────────────────────
# PartsPro AI Agent Service — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy ไฟล์นี้เป็น .env แล้วกรอกค่าที่ถูกต้อง
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] API Key จาก https://opentyphoon.ai
TYPHOON_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Path ไปยังโฟลเดอร์ที่มี database.py และ bills_v2.db
# สำหรับ local development (relative path จาก agent_service/)
BACKEND_PATH=../ai_bill_scanner

# [OPTIONAL] URL ของ Agent Service (สำหรับ agent_client.py ใน backend หลัก)
# เปลี่ยนเป็น IP/domain จริงเมื่อ deploy บน server
AGENT_SERVICE_URL=http://localhost:8001

# [OPTIONAL] Port ที่ agent_service จะรัน (default: 8001)
AGENT_PORT=8001

# ─────────────────────────────────────────────────────────────────────────────
# Backend หลัก (ai_bill_scanner) — ใส่ใน .env ของ backend ด้วย
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Google Gemini API Key สำหรับ extract_bill_data (OCR บิล)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] LINE Official Account credentials
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
