# ─────────────────────────────────────────────────────────────────────────────
# agent_service/.env — AI Agent Microservice
# ─────────────────────────────────────────────────────────────────────────────
# cp .env.example .env  แล้วกรอกค่าจริง

# [REQUIRED] Typhoon LLM API Key จาก https://opentyphoon.ai
TYPHOON_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] URL ของ Backend (main.py) — เปลี่ยนเป็น IP จริงตอน deploy
BACKEND_API_URL=http://localhost:8000

# [REQUIRED] Shared secret ระหว่าง agent ↔ backend (ต้องตรงกันทั้งสองฝั่ง)
AGENT_API_KEY=your-secret-key-change-this

# [OPTIONAL] Port ที่ agent service รัน
AGENT_PORT=8001
